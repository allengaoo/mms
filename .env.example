# MMS 环境变量配置示例
# 复制为 .env 并填写你的实际 Key

# ── 阿里云百炼（主力小模型）────────────────────────────────────────────────────
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  # 默认值
# MMS_BAILIAN_MODEL=qwen3-32b               # reasoning/code_review/dag
# MMS_BAILIAN_CODER_MODEL=qwen3-coder-next  # code_generation

# ── Google Gemini（可选 fallback）──────────────────────────────────────────────
# GEMINI_API_KEY=AIzaxxxxxxxx

# ── Anthropic Claude（可选 fallback）─────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ── Ollama（离线降级）──────────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_R1_MODEL=deepseek-r1:8b
# OLLAMA_CODER_MODEL=deepseek-coder-v2:16b

# ── 嵌入向量（Benchmark Hybrid RAG）──────────────────────────────────────────
# MMS_EMBED_PROVIDER=bailian             # bailian | ollama
# MMS_BAILIAN_EMBED_MODEL=text-embedding-v3
# MMS_OLLAMA_EMBED_MODEL=nomic-embed-text

# ── 模型路由覆盖（A/B 测试 / CI 固定模型）────────────────────────────────────
# MMS_TASK_MODEL_OVERRIDE=dag_orchestration:gemini,code_review:gemini

# ── 评估器配置（Benchmark）────────────────────────────────────────────────────
# MMS_EVAL_SKIP_LEVELS=3,4         # 跳过 arch_check 和 pytest（快速模式）
# MMS_EVAL_ARCH_CHECK_TIMEOUT=30
# MMS_EVAL_PYTEST_TIMEOUT=60

# ── Elasticsearch（Benchmark Hybrid RAG）──────────────────────────────────────
# ES_HOST=localhost
# ES_PORT=9200

# ── Milvus（Benchmark Hybrid RAG）────────────────────────────────────────────
# MILVUS_HOST=localhost
# MILVUS_PORT=19530
