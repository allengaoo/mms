# MMS 环境变量配置示例
# 复制为 .env.memory 并填写你的实际 Key

# ── 阿里云百炼（主力模型）──────────────────────────────────────────────────────
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  # 默认值
DASHSCOPE_MODEL_REASONING=qwen3-32b          # 意图识别 / 代码评审 / 知识蒸馏 / DAG 编排
DASHSCOPE_MODEL_CODING=qwen3-coder-next      # 代码生成

# ── Anthropic Claude（可选 fallback，人工介入兜底）────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ── 嵌入向量（Benchmark Hybrid RAG，可选）────────────────────────────────────
# DASHSCOPE_MODEL_EMBEDDING=text-embedding-v3

# ── 模型路由覆盖（A/B 测试 / CI 固定模型）────────────────────────────────────
# MMS_TASK_MODEL_OVERRIDE=code_generation:bailian_coder

# ── 评估器配置（Benchmark）────────────────────────────────────────────────────
# MMS_EVAL_SKIP_LEVELS=3,4         # 跳过 arch_check 和 pytest（快速模式）
# MMS_EVAL_ARCH_CHECK_TIMEOUT=30
# MMS_EVAL_PYTEST_TIMEOUT=60

# ── Elasticsearch（Benchmark Hybrid RAG）──────────────────────────────────────
# ES_HOST=localhost
# ES_PORT=9200

# ── Milvus（Benchmark Hybrid RAG）────────────────────────────────────────────
# MILVUS_HOST=localhost
# MILVUS_PORT=19530
